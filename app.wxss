/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica', 'Arial', sans-serif;
  transition: background-color 0.3s;
}

/* 深色模式 */
page[data-theme="dark"] {
  background-color: #1a1a1a;
  color: #e0e0e0;
}

.container {
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

page[data-theme="dark"] .card {
  background: #2d2d2d;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.3);
}

/* 按钮样式 */
.btn {
  border-radius: 50rpx;
  border: none;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  transition: all 0.3s;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.btn-secondary {
  background: #ecf0f1;
  color: #2c3e50;
}

page[data-theme="dark"] .btn-secondary {
  background: #3d3d3d;
  color: #e0e0e0;
}

.btn-success {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: #ffffff;
}

/* 输入框样式 */
.input-box {
  background: #ffffff;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  transition: all 0.3s;
  color: #2c3e50;
}

page[data-theme="dark"] .input-box {
  background: #2d2d2d;
  border-color: #404040;
  color: #e0e0e0;
}

.input-box:focus {
  border-color: #667eea;
  box-shadow: 0 0 0 6rpx rgba(102, 126, 234, 0.1);
}

/* 文本区域 */
.textarea {
  background: #ffffff;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  min-height: 300rpx;
  width: 100%;
  box-sizing: border-box;
  color: #2c3e50;
}

page[data-theme="dark"] .textarea {
  background: #2d2d2d;
  border-color: #404040;
  color: #e0e0e0;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag-primary {
  background: #e3f2fd;
  color: #1976d2;
}

page[data-theme="dark"] .tag-primary {
  background: #1a237e;
  color: #90caf9;
}

.tag-secondary {
  background: #f3e5f5;
  color: #7b1fa2;
}

page[data-theme="dark"] .tag-secondary {
  background: #4a148c;
  color: #ce93d8;
}

.tag-success {
  background: #e8f5e9;
  color: #388e3c;
}

page[data-theme="dark"] .tag-success {
  background: #1b5e20;
  color: #a5d6a7;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #e0e0e0;
  margin: 30rpx 0;
}

page[data-theme="dark"] .divider {
  background: #404040;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: #95a5a6;
}

page[data-theme="dark"] .empty-state {
  color: #757575;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

/* 主题切换按钮 */
.theme-switcher {
  position: fixed;
  top: 20rpx;
  right: 20rpx;
  z-index: 1000;
  padding: 16rpx;
  background: rgba(0, 0, 0, 0.1);
  border-radius: 50%;
  transition: all 0.3s;
}

page[data-theme="dark"] .theme-switcher {
  background: rgba(255, 255, 255, 0.1);
}

.theme-switcher:active {
  transform: scale(0.9);
}

.theme-icon {
  font-size: 40rpx;
}
