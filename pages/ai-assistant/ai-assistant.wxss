/* pages/ai-assistant/ai-assistant.wxss */
.ai-assistant-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 40rpx;
}

.header {
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 输入区域 */
.input-section {
  padding: 0 40rpx;
}

.input-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.input-item {
  margin-bottom: 30rpx;
}

.input-item:last-child {
  margin-bottom: 0;
}

.input-label {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 16rpx;
}

.input-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #2c3e50;
  line-height: 1.6;
}

.picker-value {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #2c3e50;
}

.picker-value.placeholder {
  color: #95a5a6;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.clear-btn,
.generate-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 32rpx;
  border: none;
}

.clear-btn {
  background: #ecf0f1;
  color: #2c3e50;
}

.generate-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-weight: bold;
}

.generate-btn.generating {
  opacity: 0.7;
}

/* 生成结果 */
.result-section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 0 40rpx 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #ecf0f1;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
}

.result-tags {
  display: flex;
  gap: 10rpx;
}

.tag {
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #ffffff;
}

.lyrics-content {
  margin-bottom: 30rpx;
}

.lyric-section {
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.lyric-section:last-child {
  margin-bottom: 0;
}

.section-type {
  display: block;
  font-size: 24rpx;
  color: #667eea;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.section-content {
  display: block;
  font-size: 28rpx;
  color: #2c3e50;
  line-height: 1.8;
}

/* 结果操作按钮 */
.result-actions {
  display: flex;
  gap: 15rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
  padding: 0;
}

.copy-btn {
  background: #ecf0f1;
  color: #2c3e50;
}

.regenerate-btn {
  background: #f39c12;
  color: #ffffff;
}

.use-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-weight: bold;
}

/* 历史记录入口 */
.history-entry {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx;
  margin: 0 40rpx 30rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50rpx;
  backdrop-filter: blur(10rpx);
}

.history-text {
  font-size: 28rpx;
  color: #ffffff;
}

.history-count {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 10rpx;
}

/* 使用提示 */
.tips {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 0 40rpx;
}

.tips-title {
  display: block;
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.tips-text {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 2;
  margin-bottom: 10rpx;
}

/* 深色模式 */
page[data-theme="dark"] .input-card,
page[data-theme="dark"] .result-section {
  background: #1a1a2e;
}

page[data-theme="dark"] .input-label,
page[data-theme="dark"] .result-title,
page[data-theme="dark"] .section-content {
  color: #e0e0e0;
}

page[data-theme="dark"] .input-textarea,
page[data-theme="dark"] .picker-value {
  background: #2a2a4e;
  color: #e0e0e0;
}

page[data-theme="dark"] .picker-value.placeholder {
  color: #808080;
}

page[data-theme="dark"] .clear-btn {
  background: #2a2a4e;
  color: #e0e0e0;
}

page[data-theme="dark"] .copy-btn {
  background: #2a2a4e;
  color: #e0e0e0;
}

page[data-theme="dark"] .result-header {
  border-color: #2a2a4e;
}

page[data-theme="dark"] .tips {
  background: rgba(0, 0, 0, 0.2);
}
