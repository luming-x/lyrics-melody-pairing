/* pages/ai-history/ai-history.wxss */
.history-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 40rpx;
}

.header {
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 历史记录列表 */
.history-list {
  padding: 0 40rpx;
}

.history-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #ecf0f1;
}

.card-tags {
  display: flex;
  gap: 10rpx;
}

.tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #ffffff;
}

.tag.emotion {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.tag.style {
  background: #f39c12;
}

.card-time {
  font-size: 24rpx;
  color: #95a5a6;
}

.card-content {
  margin-bottom: 20rpx;
}

.card-theme {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #2c3e50;
  margin-bottom: 10rpx;
}

.card-lyrics-preview {
  display: block;
  font-size: 24rpx;
  color: #7f8c8d;
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  border: none;
  padding: 0;
}

.view-btn {
  background: #ecf0f1;
  color: #2c3e50;
}

.copy-btn {
  background: #3498db;
  color: #ffffff;
}

.use-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-weight: bold;
}

.delete-btn {
  background: #e74c3c;
  color: #ffffff;
}

/* 清空按钮 */
.clear-section {
  padding: 0 40rpx;
}

.clear-all-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: rgba(231, 76, 60, 0.2);
  border: 2rpx solid #e74c3c;
  color: #e74c3c;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 深色模式 */
page[data-theme="dark"] .history-card {
  background: #1a1a2e;
}

page[data-theme="dark"] .card-theme {
  color: #e0e0e0;
}

page[data-theme="dark"] .card-lyrics-preview {
  color: #a0a0a0;
}

page[data-theme="dark"] .card-header {
  border-color: #2a2a4e;
}

page[data-theme="dark"] .view-btn {
  background: #2a2a4e;
  color: #e0e0e0;
}

page[data-theme="dark"] .card-time {
  color: #808080;
}
