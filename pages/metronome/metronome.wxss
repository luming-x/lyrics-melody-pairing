/* pages/metronome/metronome.wxss */
.metronome-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
  padding-bottom: 80rpx;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* BPM显示 */
.bpm-display {
  text-align: center;
  margin-bottom: 60rpx;
}

.bpm-value {
  display: block;
  font-size: 120rpx;
  font-weight: bold;
  color: #ffffff;
  line-height: 1;
}

.bpm-unit {
  display: block;
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 10rpx;
}

/* 播放按钮 */
.play-button {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 60rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s;
}

.play-button.playing {
  background: #ff6b6b;
}

.play-icon {
  font-size: 80rpx;
  color: #667eea;
}

.play-button.playing .play-icon {
  color: #ffffff;
}

/* 拍数指示器 */
.beat-indicator {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 60rpx;
}

.beat-dot {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.8);
  transition: all 0.2s;
}

.beat-dot.active {
  background: #ffffff;
  color: #667eea;
  transform: scale(1.1);
}

/* BPM控制 */
.bpm-controls {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 40rpx;
  background: rgba(255, 255, 255, 0.1);
  padding: 30rpx;
  border-radius: 20rpx;
}

.control-btn {
  width: 80rpx;
  height: 80rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #667eea;
  border: none;
  padding: 0;
  margin: 0;
}

.bpm-slider {
  flex: 1;
}

/* 预设 */
.presets {
  margin-bottom: 40rpx;
}

.presets-title {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 20rpx;
}

.presets-scroll {
  white-space: nowrap;
}

.preset-item {
  display: inline-block;
  padding: 16rpx 32rpx;
  margin-right: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #ffffff;
  transition: all 0.3s;
}

.preset-item.active {
  background: #ffffff;
  color: #667eea;
  font-weight: bold;
}

/* 设置按钮 */
.settings-toggle {
  text-align: center;
  padding: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
}

/* 设置面板 */
.settings-panel {
  display: none;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.settings-panel.show {
  display: block;
}

.settings-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.settings-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
}

.close-btn {
  font-size: 36rpx;
  color: #95a5a6;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #ecf0f1;
}

.setting-label {
  font-size: 28rpx;
  color: #2c3e50;
}

.picker-value {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #667eea;
}

.volume-slider {
  flex: 1;
  margin: 0 20rpx;
}

.volume-value {
  font-size: 28rpx;
  color: #95a5a6;
  min-width: 80rpx;
  text-align: right;
}

.reset-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
  margin-top: 30rpx;
}

/* 使用提示 */
.tips {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 40rpx;
}

.tips-title {
  display: block;
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.tips-text {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 2;
  margin-bottom: 10rpx;
}

/* 深色模式 */
page[data-theme="dark"] .settings-panel {
  background: #1a1a2e;
}

page[data-theme="dark"] .settings-title {
  color: #e0e0e0;
}

page[data-theme="dark"] .setting-label {
  color: #e0e0e0;
}

page[data-theme="dark"] .picker-value {
  background: #2a2a4e;
}

page[data-theme="dark"] .tips {
  background: rgba(0, 0, 0, 0.2);
}
