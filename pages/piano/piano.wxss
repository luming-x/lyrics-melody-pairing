/* 钢琴页面样式 */
.piano-page {
  min-height: 100vh;
  background: linear-gradient(to bottom, #1a1a2e 0%, #16213e 100%);
  padding-bottom: 40rpx;
}

/* 顶部信息 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 30rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
}

.settings-btn {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-btn .icon {
  font-size: 40rpx;
}

/* 当前音符显示 */
.current-note {
  margin: 20rpx 30rpx 40rpx;
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  text-align: center;
}

.note-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 16rpx;
}

.note-value {
  display: block;
  font-size: 64rpx;
  font-weight: bold;
  color: #ffd700;
}

/* 键盘容器 */
.keyboard-container {
  margin: 0 30rpx 40rpx;
}

/* 音符历史 */
.note-history {
  margin: 0 30rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  padding: 30rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.clear-btn {
  font-size: 24rpx;
  color: #ff6b6b;
}

.history-content {
  white-space: nowrap;
}

.history-list {
  display: inline-flex;
  gap: 16rpx;
}

.history-item {
  flex-shrink: 0;
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.history-note {
  font-size: 24rpx;
  color: white;
  font-weight: bold;
}

.history-empty {
  padding: 40rpx;
  text-align: center;
}

.empty-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 设置面板 */
.settings-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.settings-content {
  width: 100%;
  max-height: 80vh;
  background: #1a1a2e;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.settings-header {
  margin-bottom: 40rpx;
}

.settings-title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.setting-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.setting-value {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  color: white;
}

.arrow {
  color: rgba(255, 255, 255, 0.4);
  font-size: 32rpx;
}

.switch {
  transform: scale(1.2);
}
