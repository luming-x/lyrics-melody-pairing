/* 音高识别页面样式 */
.pitch-page {
  min-height: 100vh;
  background: linear-gradient(to bottom, #1a1a2e 0%, #16213e 100%);
  padding-bottom: 40rpx;
}

/* 当前音高显示 */
.pitch-display {
  text-align: center;
  padding: 60rpx 30rpx 40rpx;
}

.note-container {
  margin-bottom: 30rpx;
}

.note-text {
  font-size: 120rpx;
  font-weight: bold;
  color: #ffd700;
}

.octave-text {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-left: 10rpx;
}

.frequency-info {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 30rpx;
}

.frequency-value {
  display: block;
  font-size: 36rpx;
  color: white;
  margin-bottom: 16rpx;
}

.deviation-info {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10rpx;
}

.deviation-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.deviation-value {
  font-size: 28rpx;
  font-weight: bold;
}

.deviation-value.good {
  color: #51cf66;
}

.deviation-value.poor {
  color: #ff6b6b;
}

/* 调性分析 */
.key-analysis {
  margin: 0 30rpx 40rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
}

.analysis-title {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 16rpx;
}

.key-result {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.key-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffd700;
}

.confidence-value {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 录音控制 */
.record-control {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.record-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  transition: all 0.3s;
}

.record-btn.recording {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  animation: recordPulse 1.5s ease-in-out infinite;
}

@keyframes recordPulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 0 0 0 rgba(255, 107, 107, 0.7);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 0 0 20rpx rgba(255, 107, 107, 0);
  }
}

.record-icon {
  font-size: 60rpx;
  color: white;
  margin-top: 40rpx;
}

.record-icon.pulse {
  animation: iconPulse 1s ease-in-out infinite;
}

@keyframes iconPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.record-text {
  font-size: 28rpx;
  color: white;
  font-weight: bold;
}

/* 音高历史 */
.pitch-history {
  margin: 0 30rpx 40rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 30rpx;
  max-height: 400rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.clear-btn {
  font-size: 24rpx;
  color: #ff6b6b;
}

.history-content {
  height: 300rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}

.item-note {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.note-name {
  font-size: 28rpx;
  font-weight: bold;
  color: white;
}

.note-freq {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.item-deviation {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.item-deviation.good {
  background: rgba(81, 207, 102, 0.2);
  color: #51cf66;
}

.item-deviation.poor {
  background: rgba(255, 107, 107, 0.2);
  color: #ff6b6b;
}

.history-empty {
  text-align: center;
  padding: 60rpx 0;
}

.empty-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 使用说明 */
.tips {
  margin: 0 30rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
}

.tips-title {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
  font-weight: bold;
}

.tips-text {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 12rpx;
  line-height: 1.6;
}
